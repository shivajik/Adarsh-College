{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/adarsh-college run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "dist/public",
  "framework": null,
  "routes": [
    { "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
