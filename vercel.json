{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/adarsh-college run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "artifacts/adarsh-college/dist/public",
  "framework": null,
  "build": {
    "env": {
      "PORT": "25586",
      "BASE_PATH": "/"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
