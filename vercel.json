{
  "installCommand": "npx -y pnpm@9 install --no-frozen-lockfile",
  "buildCommand": "npx -y pnpm@9 --filter @workspace/adarsh-college run build-vercel && node ./scripts/vercel-copy-dist.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/((?!assets/|favicon\\.svg|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
